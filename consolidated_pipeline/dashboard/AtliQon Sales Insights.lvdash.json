    {
      "name": "revenue_yoy",
      "displayName": "Revenue with YoY Growth",
      "queryLines": [
        "WITH yearly_revenue AS (\n",
        "  SELECT\n",
        "    year,\n",
        "    SUM(total_amount_inr) as total_revenue\n",
        "  FROM\n",
        "    fmcg.gold.vw_fact_orders\n",
        "  GROUP BY\n",
        "    year\n",
        ")\n",
        "SELECT\n",
        "  year,\n",
        "  total_revenue,\n",
        "  (\n",
        "    (total_revenue - LAG(total_revenue, 1) OVER (ORDER BY year))\n",
        "      / NULLIF(LAG(total_revenue, 1) OVER (ORDER BY year), 0)\n",
        "  )\n",
        "    * 100 as yoy_growth_rate\n",
        "FROM\n",
        "  yearly_revenue\n",
        "ORDER BY\n",
        "  year"
      ],
      "catalog": "fmcg",
      "schema": "gold"
    }
  ],
